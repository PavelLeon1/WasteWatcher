# ============================================================
#  Disk Space Analyzer — .gitignore
#  Учитывает: Python, Windows, агентную разработку Qwen Code
# ============================================================


# ------------------------------------------------------------
#  ВЫХОДНЫЕ ФАЙЛЫ САМОГО ПРОЕКТА
# ------------------------------------------------------------
*.html          # сгенерированные HTML-отчёты
*.json          # сырые данные сканирования (raw_data.json и т.п.)
*.log           # лог-файлы анализатора
*.cache.json    # кеш инкрементального сканирования

# Исключение: package.json и конфиги должны попасть в репо
!package.json
!package-lock.json
!.qwen/settings.json


# ------------------------------------------------------------
#  PYTHON
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Виртуальные окружения
venv/
.venv/
env/
.env/
ENV/

# Дистрибутивы и сборки
dist/
build/
*.egg-info/
*.egg
MANIFEST

# Тесты и покрытие
.pytest_cache/
.coverage
htmlcov/
.tox/
*.coveragerc

# Mypy
.mypy_cache/
.dmypy.json

# Pyright
pyrightconfig.json


# ------------------------------------------------------------
#  АГЕНТНАЯ РАЗРАБОТКА — QWEN CODE
# ------------------------------------------------------------

# Сессии и история чатов агента (могут содержать чувствительные пути)
.qwen/sessions/
.qwen/history/
.qwen/checkpoints/
.qwen/cache/

# Временные файлы агента
.qwen/*.tmp
.qwen/*.bak

# Артефакты субагентов
.qwen/tasks/
.qwen/scratch/

# НЕ игнорировать — конфиг и навыки нужны всей команде:
!.qwen/settings.json
!.qwen/skills/


# ------------------------------------------------------------
#  ВРЕМЕННЫЕ И РАБОЧИЕ ФАЙЛЫ РАЗРАБОТКИ
# ------------------------------------------------------------

# Тестовые отчёты, создаваемые при проверках по шагам
test_report.html
test*.html
/tmp/

# Временные файлы при итерациях
*.bak
*.orig
*.swp
*~


# ------------------------------------------------------------
#  WINDOWS
# ------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk


# ------------------------------------------------------------
#  РЕДАКТОРЫ И IDE
# ------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*.swp
*.swo
.#*
\#*#


# ------------------------------------------------------------
#  ЧУВСТВИТЕЛЬНЫЕ ДАННЫЕ
# ------------------------------------------------------------

# Переменные окружения с ключами
.env
.env.local
.env.*.local

# Ключи и сертификаты
*.pem
*.key
*.p12
