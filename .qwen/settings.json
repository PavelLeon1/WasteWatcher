{
  "tools": {
    "core": [
      "ReadFileTool",
      "WriteFileTool",
      "EditFileTool",
      "ShellTool",
      "GlobTool",
      "GrepTool",
      "LSTool"
    ]
  },
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "timeout": 30000,
      "trust": true,
      "description": "Прямой доступ к файлам проекта — чтение, запись, создание"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "timeout": 60000,
      "trust": true,
      "description": "Пошаговое обдумывание сложных задач перед написанием кода"
    }
  },
  "model": {
    "name": "coder-model"
  },
  "mcp": {
    "allowed": [
      "filesystem",
      "sequential-thinking"
    ]
  },
  "$version": 3
}